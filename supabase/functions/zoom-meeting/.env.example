# Zoom Server-to-Server OAuth app credentials.
# Create the app at https://marketplace.zoom.us → Develop → Build App → "Server-to-Server OAuth".
# Grant the meeting:write:admin and meeting:read:admin scopes, then copy the three values below.
#
# These are SECRET and must never ship in the client bundle. Set them as Supabase
# function secrets (they are injected into the edge function at runtime):
#   supabase secrets set ZOOM_ACCOUNT_ID=... ZOOM_CLIENT_ID=... ZOOM_CLIENT_SECRET=...
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
