# Supabase — Anglian Tutoring (project ref: peohauhwquuvghrpmotf)
# The URL and publishable key are safe to expose (they ship in the client bundle).
# The service role key is SECRET — never commit a real value. Copy it from the
# Supabase dashboard: Project Settings → API → service_role.

# Server-side (SSR / server functions)
SUPABASE_PROJECT_ID=peohauhwquuvghrpmotf
SUPABASE_URL=https://peohauhwquuvghrpmotf.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_MdTxLYK6CMmNKrsL_HTktg_g05RBAV0
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — SECRET, server/script only. Never prefix this with VITE_: that would
# ship your secret key to every browser. Used by scripts/stripe-seed.ts; the
# edge functions read it from Supabase function secrets, not from here.
# Dashboard: Developers → API keys. Use sk_test_… until you're taking real money.
STRIPE_SECRET_KEY=

# Client-side (Vite build-time, VITE_ prefix is exposed to the browser)
VITE_SUPABASE_PROJECT_ID=peohauhwquuvghrpmotf
VITE_SUPABASE_URL=https://peohauhwquuvghrpmotf.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_MdTxLYK6CMmNKrsL_HTktg_g05RBAV0
